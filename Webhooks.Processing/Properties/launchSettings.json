{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5170",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "http://192.168.0.12:18889",
        "OTEL_RESOURCE_ATTRIBUTES": "service.name=webhooks-processing-local"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:7105;http://localhost:5170",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "http://192.168.0.12:18889",
        "OTEL_RESOURCE_ATTRIBUTES": "service.name=webhooks-processing-local"
      }
    },
    "Homelab": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7200;http://localhost:5200",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__WebhooksDatabase": "Host=192.168.0.12;Port=5432;Username=postgres;Password=postgres;Database=WebhooksDatabase",
        "ConnectionStrings__rabbitmq": "amqp://rabbit:rabbit@192.168.0.12:5672/",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "http://192.168.0.12:4317",
        "OTEL_RESOURCE_ATTRIBUTES": "service.name=webhooks-processing-local"
